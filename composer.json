{
    "name": "llm/skills",
    "type": "composer-plugin",
    "description": "AI skills discovery and management system for LLM agents",
    "license": "BSD-3-Clause",
    "support": {
        "issues": "https://github.com/roxblnfk/skills/issues",
        "source": "https://github.com/roxblnfk/skills"
    },
    "authors": [
        {
            "name": "Aleksei Gagarin",
            "email": "roxblnfk@gmail.com"
        }
    ],
    "funding": [
        {
            "type": "boosty",
            "url": "https://boosty.to/roxblnfk"
        }
    ],
    "require": {
        "php": ">=8.2",
        "composer-plugin-api": "^2.0",
        "internal/path": "^1.2"
    },
    "require-dev": {
        "buggregator/trap": "^1.10",
        "composer/composer": "^2.9.0",
        "infection/infection": "dev-testo-bridge-82 as 0.32.6",
        "roxblnfk/unpoly": "^1.8",
        "spiral/code-style": "^2.3",
        "testo/bridge-infection": "0.1 - 1",
        "testo/testo": "0.1 - 1",
        "vimeo/psalm": "^7"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/roxblnfk/infection"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": ["bin/skills"],
    "autoload": {
        "psr-4": {
            "LLM\\Skills\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LLM\\Skills\\Tests\\": "tests/"
        }
    },
    "extra": {
        "class": "LLM\\Skills\\Composer\\SkillsPlugin"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "scripts": {
        "cs:diff": "php-cs-fixer fix --dry-run -v --diff",
        "cs:fix": "php-cs-fixer fix -v",
        "psalm": "psalm",
        "psalm:baseline": "psalm --set-baseline=psalm-baseline.xml",
        "psalm:ci": "psalm --output-format=github --shepherd --show-info=false --stats --threads=4",
        "test": [
            "@putenv XDEBUG_MODE=coverage",
            "testo"
        ],
        "test:ci": [
            "@putenv TESTO_CI=1",
            "@putenv XDEBUG_MODE=coverage",
            "testo"
        ],
        "infect": [
            "@putenv XDEBUG_MODE=coverage",
            "infection --configuration=infection.json  --threads=max"
        ],
        "infect:ci": [
            "@putenv TESTO_CI=1",
            "@putenv XDEBUG_MODE=coverage",
            "infection --ansi --configuration=infection.json --logger-github  --threads=max --show-mutations=0"
        ]
    }
}
