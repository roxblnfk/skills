{
    "name": "llm/skills-sandbox",
    "description": "Test consumer project for acceptance tests in tests/Acceptance",
    "type": "project",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        { "type": "path", "url": "../../..",        "options": { "symlink": true } },
        { "type": "path", "url": "../packages/*/*", "options": { "symlink": true } }
    ],
    "require": {
        "llm/skills": "@dev",
        "acme/skills-basic": "@dev",
        "acme/skills-pro": "@dev",
        "acme/skills-broken": "@dev",
        "acme/skills-rootlike": "@dev",
        "acme/skills-undeclared": "@dev",
        "spiral/skills-demo": "@dev",
        "transit/untrusted-relay": "@dev"
    },
    "config": {
        "allow-plugins": {
            "llm/skills": true
        }
    },
    "extra": {
        "skills": {
            "trusted": ["acme/skills-basic", "acme/skills-pro"]
        }
    }
}
