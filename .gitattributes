# Line-ending normalization for text files.
* text=auto

# PHP-aware hunk headers in `git diff`.
*.php diff=php

# Binary files keep their bytes.
*.gpg binary
*.phar binary

# Default: nothing is included in the `composer archive` of llm/skills.
# Re-include only the files that actually belong to the distributed package below.
* export-ignore

# Top-level metadata.
/composer.json   -export-ignore
/LICENSE.md      -export-ignore

# Source code (`LLM\Skills\` namespace), packaged resources and CLI entry point.
/src             -export-ignore
/src/**          -export-ignore
/resources       -export-ignore
/resources/**    -export-ignore
/bin             -export-ignore
/bin/**          -export-ignore
